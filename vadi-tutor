function updateModel(category, isCorrect, userAnswer, correctAnswer) {
  if (!isCorrect) {
    studentModel.weakCategories[category] =
      (studentModel.weakCategories[category] || 0) + 1;

    studentModel.mistakes.push({
      category,
      userAnswer,
      correctAnswer
    });
  } else {
    studentModel.streak++;
  }

  // 📈 адаптация сложности
  const totalMistakes = Object.values(studentModel.weakCategories)
    .reduce((a, b) => a + b, 0);

  studentModel.level = Math.max(1, Math.floor(totalMistakes / 5) + 1);
}
const prompt = `
